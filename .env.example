# ============================================================
# Arconti31 — template variabili ambiente
# ============================================================
# QUESTO FILE NON CONTIENE SECRET REALI.
#
# Uso:
# 1) Copia in un file LOCALE (non committare):
#      cp .env.example .env.local
# 2) Compila i valori reali SOLO in .env.local (o meglio: solo su Netlify)
# 3) Su Netlify del CLIENTE: Site configuration → Environment variables
#    → inserisci le stesse chiavi/valori → Trigger deploy
#
# .env / .env.local sono in .gitignore e NON vanno su GitHub.
# ============================================================

# --- GitHub (repo del cliente) ---
REPO_OWNER=arconti31
REPO_NAME=Arconti31
GITHUB_BRANCH=main
# Token Classic del cliente, scope "repo" (inizia con ghp_)
GITHUB_TOKEN=ghp_INSERISCI_QUI

# --- Login CMS (/admin) ---
# Una o più email separate da virgola
ADMIN_EMAIL=arconti31gallarate@libero.it
ADMIN_PASSWORD=INSERISCI_PASSWORD_CMS_FORTE

# Segreto per firmare le sessioni CMS (NON usare la password)
# Genera con: openssl rand -base64 48
CMS_TOKEN_SECRET=INSERISCI_OUTPUT_OPENSSL

# --- Cloudinary (upload immagini) ---
CLOUDINARY_CLOUD_NAME=ducwseofw
CLOUDINARY_UPLOAD_PRESET=arconti31_unsigned
CLOUDINARY_FOLDER=arconti31
# Da Cloudinary → Settings → API Keys
CLOUDINARY_API_KEY=INSERISCI_API_KEY
CLOUDINARY_API_SECRET=INSERISCI_API_SECRET

# --- Opzionale ---
# ALLOWED_ORIGINS=https://arconti31.com,https://www.arconti31.com
